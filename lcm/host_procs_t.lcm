package dpm_msgs;

struct host_procs_t
{
    // DPM wire-protocol version — consumers drop messages with a mismatching
    // version. See dpm.constants.DPM_PROTOCOL_VERSION.
    int32_t protocol_version;

    // useconds since Unix Epoch
    int64_t timestamp;

    // Remote host name
    string hostname;

    // number of procs managed by the remote host procman3
    int32_t num_procs;

    //procs info
    proc_info_t procs[num_procs];
}
