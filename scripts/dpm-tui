#!/usr/bin/env bash
# Lightweight launcher that runs the packaged dpm GUI without installing with pip.
# Usage: scripts/dpm-gui [args]
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# Run from repository root so relative paths (dpm.yaml, node/, logs/, saved/) work
cd "$REPO_ROOT"

# Ensure src/ is on PYTHONPATH so 'python -m dpm.gui.app' can import the package
export PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}"

# Run the GUI module
exec python3 -m dpm.tui.app "$@"
